---
const title = "Fil — Your terminals, everywhere.";
const description = "Access your Mac terminal sessions from your iPhone. QUIC transport, E2E encrypted, built in Rust.";
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://fil.sh" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>

<body>
  <!-- Nav -->
  <nav>
    <div class="nav-inner">
      <a href="/" class="logo">fil<span>.sh</span></a>
      <div class="nav-links">
        <a href="#features" class="nav-link">Features</a>
        <a href="#stack" class="nav-link">Stack</a>
        <a href="https://github.com/Remenby31/fil" class="nav-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-badge reveal">QUIC transport · E2E encrypted · Open source</div>
    <h1 class="reveal">Your terminals,<br><em>everywhere</em>.</h1>
    <p class="reveal delay-1">Open a terminal on your Mac. Pick it up on your iPhone.<br>One invisible thread connecting your sessions across devices.</p>

    <div class="install-cmd reveal delay-2" onclick="navigator.clipboard.writeText('curl -fsSL https://fil.sh/install.sh | sh'); this.classList.add('copied')">
      <span class="install-prompt">$</span>
      <span class="install-text">curl -fsSL https://fil.sh/install.sh | sh</span>
      <span class="install-copy">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      </span>
    </div>

    <div class="cli-preview reveal delay-3">
      <div class="cli-bar">
        <div class="cli-dot red"></div>
        <div class="cli-dot yellow"></div>
        <div class="cli-dot green"></div>
        <span class="cli-title">Terminal</span>
      </div>
      <div class="cli-body">
        <div class="type-line" style="--delay: 0s"><span class="dim">$</span> <span class="cmd">curl -fsSL https://fil.sh/install.sh | sh</span></div>
        <div class="type-line" style="--delay: 0.8s"><span class="dim">$</span> <span class="cmd">fil setup</span></div>
        <div class="type-line" style="--delay: 1.6s">&nbsp;</div>
        <div class="type-line" style="--delay: 2.0s"><span class="ok">  ✓</span> <span class="dim">Signed in as</span> <span class="cmd">Baptiste</span></div>
        <div class="type-line" style="--delay: 2.4s"><span class="ok">  ✓</span> <span class="dim">Device</span> <span class="cmd">MacBook-Pro</span> <span class="dim">registered</span></div>
        <div class="type-line" style="--delay: 2.8s"><span class="ok">  ✓</span> <span class="dim">Connected via QUIC</span></div>
        <div class="type-line" style="--delay: 3.4s">&nbsp;</div>
        <div class="type-line" style="--delay: 3.8s"><span class="dim">  Ready. Open Fil on your iPhone.</span></div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features" id="features">
    <h2 class="section-title reveal">Built for developers<br>who <em>ship</em>.</h2>

    <div class="feature-grid">
      <div class="feature-card reveal">
        <div class="feature-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
        </div>
        <h3>Real-time access</h3>
        <p>See every terminal session from your iPhone. Tap to connect, type commands, full native experience.</p>
      </div>
      <div class="feature-card reveal">
        <div class="feature-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
        <h3>Multi-machine</h3>
        <p>All your Macs, one hub. Switch between machines in a tap. Sessions aggregated across devices.</p>
      </div>
      <div class="feature-card reveal">
        <div class="feature-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        </div>
        <h3>Smart notifications</h3>
        <p>Build finished. Agent needs approval. Command failed. Only what matters, zero noise.</p>
      </div>
      <div class="feature-card reveal">
        <div class="feature-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
        </div>
        <h3>Dynamic Island</h3>
        <p>Running processes live on your lock screen. Command name, elapsed time. Tap to jump in.</p>
      </div>
      <div class="feature-card reveal">
        <div class="feature-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <h3>End-to-end encrypted</h3>
        <p>Noise Protocol, ChaCha20-Poly1305. The hub routes bytes without ever reading them.</p>
      </div>
      <div class="feature-card reveal">
        <div class="feature-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3>Self-hostable</h3>
        <p>One Docker command. Your data, your infra. Or use our hosted version — zero config.</p>
      </div>
    </div>
  </section>

  <!-- Built with -->
  <section class="stack" id="stack">
    <h2 class="section-title reveal">Built with the<br><em>best</em> tools.</h2>
    <div class="stack-grid reveal">
      <div class="stack-item">
        <div class="stack-logo">
          <svg width="36" height="36" viewBox="0 0 40 40" fill="none"><path d="M20 4L4 12v16l16 8 16-8V12L20 4z" stroke="var(--fil-green)" stroke-width="1.5" fill="none"/><path d="M4 12l16 8 16-8M20 20v16" stroke="var(--fil-green)" stroke-width="1.5"/><circle cx="20" cy="20" r="3" fill="var(--fil-green)" opacity="0.6"/></svg>
        </div>
        <div class="stack-label">Transport</div>
        <div class="stack-name">QUIC</div>
        <div class="stack-desc">UDP, 0-RTT, connection migration</div>
      </div>
      <div class="stack-item">
        <div class="stack-logo">
          <svg width="36" height="36" viewBox="0 0 40 40" fill="none"><rect x="6" y="8" width="28" height="24" rx="3" stroke="var(--fil-green)" stroke-width="1.5"/><path d="M6 14h28" stroke="var(--fil-green)" stroke-width="1.5"/><circle cx="20" cy="22" r="4" stroke="var(--fil-green)" stroke-width="1.5"/><path d="M17.5 22h5M20 19.5v5" stroke="var(--fil-green)" stroke-width="1.5" stroke-linecap="round"/></svg>
        </div>
        <div class="stack-label">Encryption</div>
        <div class="stack-name">Noise Protocol</div>
        <div class="stack-desc">ChaCha20-Poly1305, E2E</div>
      </div>
      <div class="stack-item">
        <div class="stack-logo">
          <svg width="36" height="36" viewBox="0 0 40 40" fill="none"><path d="M20 6C13 6 8 10 8 15c0 3.5 2 6 5 7.5V34l7-4 7 4V22.5c3-1.5 5-4 5-7.5 0-5-5-9-12-9z" stroke="var(--fil-green)" stroke-width="1.5" fill="none"/><circle cx="16" cy="16" r="2" fill="var(--fil-green)" opacity="0.5"/><circle cx="24" cy="16" r="2" fill="var(--fil-green)" opacity="0.5"/></svg>
        </div>
        <div class="stack-label">Backend</div>
        <div class="stack-name">Rust</div>
        <div class="stack-desc">Daemon + Hub, zero-copy I/O</div>
      </div>
      <div class="stack-item">
        <div class="stack-logo">
          <svg width="36" height="36" viewBox="0 0 40 40" fill="none"><rect x="8" y="4" width="24" height="32" rx="4" stroke="var(--fil-green)" stroke-width="1.5"/><line x1="8" y1="10" x2="32" y2="10" stroke="var(--fil-green)" stroke-width="1.5"/><line x1="8" y1="30" x2="32" y2="30" stroke="var(--fil-green)" stroke-width="1.5"/><rect x="12" y="14" width="16" height="12" rx="1" stroke="var(--fil-green)" stroke-width="1" opacity="0.5"/><path d="M15 18l3 3 6-6" stroke="var(--fil-green)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="stack-label">iOS</div>
        <div class="stack-name">SwiftUI</div>
        <div class="stack-desc">Native, SwiftTerm, TCA</div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="how" id="how">
    <h2 class="section-title reveal">Three steps.<br><em>Two</em> minutes.</h2>
    <div class="steps">
      <div class="step reveal">
        <div class="step-number">1</div>
        <h3>Install</h3>
        <p>One command. Works on any Mac.</p>
        <code>curl -fsSL https://fil.sh/install.sh | sh</code>
      </div>
      <div class="step reveal">
        <div class="step-number">2</div>
        <h3>Authenticate</h3>
        <p>Sign in with GitHub. Browser opens, done.</p>
        <code>fil setup</code>
      </div>
      <div class="step reveal">
        <div class="step-number">3</div>
        <h3>Connect</h3>
        <p>Open the app on your iPhone. Sessions are there.</p>
        <code>fil</code>
      </div>
    </div>
  </section>

  <!-- Self-host -->
  <section class="selfhost reveal">
    <h2>Own your data.</h2>
    <p>Run the Fil hub on your own server.</p>
    <code>docker run -d -p 3100:3100 -p 16433:16433/udp fil/hub</code>
  </section>

  <!-- Footer -->
  <footer>
    <div class="footer-inner">
      <a href="/" class="logo">fil<span>.sh</span></a>
      <div class="links">
        <a href="https://github.com/Remenby31/fil">GitHub</a>
        <a href="/privacy">Privacy</a>
        <a href="mailto:hello@fil.sh">Contact</a>
      </div>
      <div class="copy">© 2026 Fil. MIT License.</div>
    </div>
  </footer>

  <!-- Scroll reveal script -->
  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>
</body>
</html>

<style>
  :root {
    --void: #0A0A0F;
    --fil-green: #00D4AA;
    --surface: #12121A;
    --cloud: #FAFAFA;
    --depth: #0D1117;
    --fil-light: #55EFC4;
    --text-secondary: rgba(250,250,250,0.45);
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Inter', -apple-system, sans-serif;
    background: var(--void);
    color: var(--cloud);
    overflow-x: hidden;
  }

  /* Scroll reveal */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .delay-1 { transition-delay: 0.1s; }
  .delay-2 { transition-delay: 0.2s; }
  .delay-3 { transition-delay: 0.3s; }

  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; transition: none; }
  }

  /* Nav */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10,10,15,0.8);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo { font-size: 20px; font-weight: 300; color: var(--cloud); text-decoration: none; }
  .logo span { color: var(--fil-green); }
  .nav-links { display: flex; gap: 24px; align-items: center; }
  .nav-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    transition: color 0.2s;
    display: inline-flex;
    align-items: center;
  }
  .nav-link:hover { color: var(--cloud); }

  /* Hero */
  .hero {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
    padding: 80px 24px 60px;
  }
  .hero-badge {
    display: inline-block;
    font-size: 12px;
    font-weight: 500;
    color: var(--fil-green);
    background: rgba(0,212,170,0.08);
    border: 1px solid rgba(0,212,170,0.15);
    padding: 6px 16px;
    border-radius: 100px;
    margin-bottom: 28px;
    letter-spacing: 0.3px;
  }
  .hero h1 {
    font-size: clamp(36px, 6vw, 72px);
    font-weight: 300;
    line-height: 1.1;
    margin-bottom: 20px;
    letter-spacing: -2px;
  }
  .hero h1 em, .section-title em { font-style: normal; color: var(--fil-green); }
  .hero p {
    font-size: 17px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 36px;
  }

  /* Install command */
  .install-cmd {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    background: var(--depth);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    margin-bottom: 40px;
  }
  .install-cmd:hover { border-color: var(--fil-green); background: rgba(0,212,170,0.04); }
  .install-prompt { color: var(--fil-green); font-family: 'JetBrains Mono', monospace; font-size: 13px; }
  .install-text { color: var(--cloud); font-family: 'JetBrains Mono', monospace; font-size: 13px; }
  .install-copy { color: rgba(250,250,250,0.2); transition: color 0.2s; }
  .install-cmd:hover .install-copy { color: var(--fil-green); }
  .install-cmd.copied .install-copy { color: var(--fil-green); }

  /* CLI Preview */
  .cli-preview {
    max-width: 560px;
    margin: 0 auto;
    background: var(--depth);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 10px;
    overflow: hidden;
    text-align: left;
  }
  .cli-bar {
    padding: 10px 14px;
    display: flex;
    gap: 6px;
    align-items: center;
    background: rgba(255,255,255,0.02);
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .cli-dot { width: 10px; height: 10px; border-radius: 50%; }
  .cli-dot.red { background: #ff5f57; }
  .cli-dot.yellow { background: #febc2e; }
  .cli-dot.green { background: #28c840; }
  .cli-title { font-size: 11px; color: rgba(250,250,250,0.25); margin-left: auto; margin-right: auto; }
  .cli-body { padding: 16px 18px; font-family: 'JetBrains Mono', monospace; font-size: 12px; line-height: 1.9; }
  .dim { color: rgba(250,250,250,0.3); }
  .cmd { color: var(--cloud); }
  .ok { color: var(--fil-green); }

  .type-line {
    opacity: 0;
    animation: typeIn 0.3s ease forwards;
    animation-delay: var(--delay);
  }
  @keyframes typeIn {
    from { opacity: 0; transform: translateX(-4px); }
    to { opacity: 1; transform: translateX(0); }
  }

  /* Section titles */
  .section-title {
    text-align: center;
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 300;
    letter-spacing: -1px;
    margin-bottom: 56px;
    line-height: 1.2;
  }

  /* Features */
  .features {
    max-width: 1100px;
    margin: 0 auto;
    padding: 100px 24px;
  }
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .feature-card {
    background: var(--surface);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 12px;
    padding: 28px 24px;
    transition: border-color 0.3s, transform 0.3s;
  }
  .feature-card:hover {
    border-color: rgba(0,212,170,0.15);
    transform: translateY(-2px);
  }
  .feature-icon-wrap {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,212,170,0.08);
    border-radius: 8px;
    margin-bottom: 16px;
    color: var(--fil-green);
  }
  .feature-card h3 { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
  .feature-card p { font-size: 13px; color: var(--text-secondary); line-height: 1.6; }

  /* Stack */
  .stack {
    max-width: 1100px;
    margin: 0 auto;
    padding: 80px 24px;
  }
  .stack-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .stack-item {
    text-align: center;
    padding: 32px 20px;
    background: var(--surface);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 12px;
    transition: border-color 0.3s;
  }
  .stack-item:hover { border-color: rgba(0,212,170,0.15); }
  .stack-logo {
    margin-bottom: 14px;
  }
  .stack-label {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--fil-green);
    margin-bottom: 8px;
  }
  .stack-name {
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 6px;
  }
  .stack-desc {
    font-size: 12px;
    color: var(--text-secondary);
  }

  /* How it works */
  .how {
    max-width: 900px;
    margin: 0 auto;
    padding: 80px 24px;
  }
  .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .step { text-align: center; }
  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px; height: 36px;
    border-radius: 50%;
    background: var(--fil-green);
    color: var(--void);
    font-weight: 700;
    font-size: 14px;
    margin-bottom: 14px;
  }
  .step h3 { font-size: 15px; font-weight: 600; margin-bottom: 6px; }
  .step p { font-size: 13px; color: var(--text-secondary); line-height: 1.6; margin-bottom: 10px; }
  .step code {
    display: inline-block;
    padding: 6px 12px;
    background: var(--depth);
    border-radius: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--fil-green);
    border: none;
  }

  /* Self-host */
  .selfhost {
    max-width: 600px;
    margin: 0 auto;
    padding: 80px 24px;
    text-align: center;
  }
  .selfhost h2 { font-size: 28px; font-weight: 300; margin-bottom: 10px; letter-spacing: -0.5px; }
  .selfhost p { color: var(--text-secondary); font-size: 14px; margin-bottom: 24px; }
  .selfhost code {
    display: inline-block;
    padding: 12px 20px;
    background: var(--depth);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--fil-green);
  }

  /* Footer */
  footer {
    border-top: 1px solid rgba(255,255,255,0.04);
  }
  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 40px 24px 32px;
    text-align: center;
  }
  footer .logo { font-size: 18px; display: block; margin-bottom: 14px; }
  .links { display: flex; justify-content: center; gap: 20px; margin-bottom: 16px; }
  footer a { color: rgba(250,250,250,0.35); text-decoration: none; font-size: 12px; transition: color 0.2s; }
  footer a:hover { color: var(--cloud); }
  .copy { font-size: 11px; color: rgba(250,250,250,0.15); }

  /* Responsive */
  @media (max-width: 768px) {
    .feature-grid { grid-template-columns: 1fr; }
