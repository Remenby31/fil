---
const title = "Fil — Your terminals, everywhere.";
const description = "Access your Mac terminal sessions from your iPhone. QUIC transport, E2E encrypted, built in Rust.";
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://fil.sh" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>

<body>
  <!-- Nav -->
  <nav>
    <div class="nav-inner">
      <a href="/" class="logo">fil<span>.sh</span></a>
      <div class="nav-links">
        <a href="#features" class="nav-link">Features</a>
        <a href="#stack" class="nav-link">Stack</a>
        <a href="https://github.com/Remenby31/fil" class="nav-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-badge reveal">QUIC transport · E2E encrypted · Open source</div>
    <h1 class="reveal">Your terminals,<br><em>everywhere</em>.</h1>
    <p class="reveal delay-1">Open a terminal on your Mac. Pick it up on your iPhone.<br>One invisible thread connecting your sessions across devices.</p>

    <div class="install-cmd reveal delay-2" onclick="navigator.clipboard.writeText('curl -fsSL https://fil.sh/install.sh | sh'); this.classList.add('copied')">
      <span class="install-prompt">$</span>
      <span class="install-text">curl -fsSL https://fil.sh/install.sh | sh</span>
      <span class="install-copy">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      </span>
    </div>

    <div class="cli-preview reveal delay-3">
      <div class="cli-bar">
        <div class="cli-dot red"></div>
        <div class="cli-dot yellow"></div>
        <div class="cli-dot green"></div>
        <span class="cli-title">Terminal</span>
      </div>
      <div class="cli-body">
        <div class="type-line" style="--delay: 0s"><span class="dim">$</span> <span class="cmd">curl -fsSL https://fil.sh/install.sh | sh</span></div>
        <div class="type-line" style="--delay: 0.8s"><span class="dim">$</span> <span class="cmd">fil setup</span></div>
        <div class="type-line" style="--delay: 1.6s">&nbsp;</div>
        <div class="type-line" style="--delay: 2.0s"><span class="ok">  ✓</span> <span class="dim">Signed in as</span> <span class="cmd">Baptiste</span></div>
        <div class="type-line" style="--delay: 2.4s"><span class="ok">  ✓</span> <span class="dim">Device</span> <span class="cmd">MacBook-Pro</span> <span class="dim">registered</span></div>
        <div class="type-line" style="--delay: 2.8s"><span class="ok">  ✓</span> <span class="dim">Connected via QUIC</span></div>
        <div class="type-line" style="--delay: 3.4s">&nbsp;</div>
        <div class="type-line" style="--delay: 3.8s"><span class="dim">  Ready. Open Fil on your iPhone.</span></div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features" id="features">
    <h2 class="section-title reveal">Built for developers<br>who <em>ship</em>.</h2>

    <div class="feature-grid">
      <div class="feature-card reveal">
        <div class="feature-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
        </div>
        <h3>Real-time access</h3>
        <p>See your sessions from iPhone. Tap, type, done.</p>
      </div>
      <div class="feature-card reveal">
        <div class="feature-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
        <h3>Multi-machine</h3>
        <p>All your Macs, one hub. Switch in a tap.</p>
      </div>
      <div class="feature-card reveal">
        <div class="feature-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        </div>
        <h3>Smart notifications</h3>
        <p>Build done. Agent waiting. Command failed.</p>
      </div>
      <div class="feature-card reveal">
        <div class="feature-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
        </div>
        <h3>Dynamic Island</h3>
        <p>Processes on your lock screen. Tap to jump in.</p>
      </div>
      <div class="feature-card reveal">
        <div class="feature-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <h3>E2E encrypted</h3>
        <p>The hub can't read your data. Nobody can.</p>
      </div>
      <div class="feature-card reveal">
        <div class="feature-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3>Self-hostable</h3>
        <p>One Docker command. Your data, your infra.</p>
      </div>
    </div>
  </section>

  <!-- Built with -->
  <section class="stack" id="stack">
    <h2 class="section-title reveal">Built with the<br><em>best</em> tools.</h2>
    <div class="stack-grid reveal">
      <div class="stack-item">
        <div class="stack-logo">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 64 64"><path d="M23.056 30.85L52.33 47.76c-.024.008-.136.104-.255.176L34.512 58.1c-1.732.998-3.465.894-5.173-.08L2.722 42.602C.894 41.557 0 39.984 0 37.876v-12.07c0-2.475 1.692-4.43 4.127-4.8 1.062-.152 2.06.072 2.986.615l4.263 2.483c.295.176.52.208.822 0l1.764-1.03-7.09-4.07c1.1-.703 2.355-.974 3.696-.623.52.152 1.022.36 1.485.63l4.143 2.395a.57.57 0 0 0 .679 0l1.836-1.07-7.17-4.087 3.105-1.804 14.697-8.478c1.764-1.022 3.537-1.022 5.31 0l26.8 15.496c1.676.966 2.54 2.467 2.54 4.4v12.167c0 1.924-.806 3.433-2.475 4.383-1.637.934-3.29.806-4.926-.144L30.29 27.06c-.255-.152-.44-.152-.68 0L27.8 28.12l29.235 16.893a4.1 4.1 0 0 1-3.018.711 6.38 6.38 0 0 1-2.14-.742l-26.21-15.144c-.32-.184-.55-.216-.862 0-.535.35-1.1.647-1.74 1.014zM41.058 43.712l-8.662 5.014a.67.67 0 0 1-.79.008L9.724 36.072c-.27-.152-.367-.335-.367-.655v-6.77c0-.36.12-.55.415-.726l13.308-7.68 8.19-4.742c.527-.32.918-.32 1.453 0l21.14 12.222c.56.32.766.663.742 1.3l-.008 6.57c-.024.176-.112.327-.255.43l-1.892 1.102c-.12.072-.343.104-.455.04l-6.6-3.816c-.032-.024-.04-.048-.088-.136l2.02-1.174-14.905-8.638c-.255-.152-.447-.216-.742-.048l-14.617 8.47-.295.192c.08.08.176.152.27.224l14.673 8.47c.16.088.447.064.63-.024.407-.176.782-.4 1.142-.663.43-.327.774-.287 1.23-.024l5.804 3.37.55.343z" fill="rgba(250,250,250,0.5)"/></svg>
        </div>
        <div class="stack-label">Transport</div>
        <div class="stack-name">QUIC</div>
        <div class="stack-desc">UDP, 0-RTT, connection migration</div>
      </div>
      <div class="stack-item">
        <div class="stack-logo">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="rgba(250,250,250,0.5)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/><circle cx="12" cy="17" r="1" fill="rgba(250,250,250,0.5)"/></svg>
        </div>
        <div class="stack-label">Encryption</div>
        <div class="stack-name">Noise Protocol</div>
        <div class="stack-desc">ChaCha20-Poly1305, E2E</div>
      </div>
      <div class="stack-item">
        <div class="stack-logo">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 32 32"><path d="M15 3.77a.951.951 0 1 1 1.902 0 .951.951 0 0 1-1.902 0M3.654 12.38a.951.951 0 1 1 1.902 0 .951.951 0 0 1-1.902 0m22.692.044a.951.951 0 0 1 1.902 0 .951.951 0 0 1-1.902 0M6.406 13.73a.87.87 0 0 0 .441-1.146l-.422-.954h1.66v7.48H4.736a11.7 11.7 0 0 1-.379-4.47zm6.942.184v-2.205H17.3c.204 0 1.44.236 1.44 1.16 0 .768-.95 1.044-1.73 1.044zM7.952 25.785a.951.951 0 1 1 1.902 0 .951.951 0 0 1-1.902 0m14.093.044a.951.951 0 0 1 1.902 0 .951.951 0 0 1-1.902 0m.294-2.157a.867.867 0 0 0-1.03.667l-.477 2.228a11.71 11.71 0 0 1-9.765-.047l-.477-2.228a.865.865 0 0 0-1.03-.667l-1.967.422a12 12 0 0 1-1.017-1.199h9.57c.108 0 .18-.02.18-.118v-3.385c0-.1-.072-.118-.18-.118h-2.8v-2.146h3.027c.276 0 1.477.08 1.862 1.614l.565 2.5c.18.55.913 1.653 1.693 1.653h4.94a12 12 0 0 1-1.085 1.255zm5.314-8.938a11.7 11.7 0 0 1 .025 2.033h-1.2c-.12 0-.17.08-.17.197v.552c0 1.3-.732 1.58-1.374 1.653-.61.07-1.29-.256-1.372-.63-.36-2.028-.96-2.46-1.9-3.21 1.177-.748 2.402-1.85 2.402-3.327 0-1.594-1.093-2.598-1.838-3.09-1.045-.69-2.202-.827-2.514-.827H7.277a11.7 11.7 0 0 1 6.551-3.697l1.465 1.537c.33.347.88.36 1.226.028l1.64-1.567a11.71 11.71 0 0 1 8.017 5.709l-1.122 2.534a.87.87 0 0 0 .441 1.146zm2.798.04-.038-.392 1.156-1.078c.235-.22.147-.66-.153-.772l-1.477-.552-.116-.38.92-1.28c.188-.26.015-.675-.3-.727l-1.558-.253-.187-.35.655-1.437c.134-.293-.115-.667-.437-.655l-1.58.055-.25-.303.363-1.54c.073-.313-.244-.63-.557-.557l-1.54.363-.304-.25.055-1.58c.012-.32-.362-.57-.654-.437l-1.436.655-.35-.188-.254-1.558c-.05-.316-.467-.488-.727-.3l-1.28.92-.38-.115L19.47.586c-.112-.3-.553-.388-.772-.154L17.62 1.588l-.392-.038-.832-1.345c-.168-.272-.62-.272-.787 0l-.832 1.345-.392.038L13.305.43c-.22-.234-.66-.147-.772.154l-.552 1.477-.38.115-1.28-.92c-.26-.188-.676-.015-.727.3L9.34 3.114l-.35.188-1.436-.655c-.292-.133-.667.117-.654.437l.055 1.58-.304.25-1.54-.363c-.313-.073-.63.244-.557.557l.363 1.54-.25.303-1.58-.055c-.32-.01-.57.362-.437.655l.655 1.437-.188.35-1.558.253c-.316.05-.488.467-.3.727l.92 1.28-.116.38-1.477.552c-.3.112-.388.553-.153.772l1.156 1.078-.038.392-1.345.832c-.272.168-.272.62 0 .787l1.345.832.038.392L.43 18.697c-.234.22-.147.66.153.772l1.477.552.116.38-.92 1.28c-.187.26-.015.676.3.727l1.557.253.188.35-.655 1.436c-.133.292.118.667.437.655l1.58-.055.25.304-.363 1.54c-.073.312.244.63.557.556l1.54-.363.304.25-.055 1.58c-.012.32.362.57.654.437l1.436-.655.35.188.254 1.557c.05.317.467.488.727.302l1.28-.922.38.116.552 1.477c.112.3.553.388.772.153l1.078-1.156.392.04.832 1.345c.168.27.618.272.787 0l.832-1.345.392-.04 1.078 1.156c.22.235.66.147.772-.153l.552-1.477.38-.116 1.28.922c.26.187.676.015.727-.302l.254-1.557.35-.188 1.436.655c.292.133.666-.116.654-.437l-.055-1.58.303-.25 1.54.363c.313.073.63-.244.557-.556l-.363-1.54.25-.304 1.58.055c.32.013.57-.363.437-.655l-.655-1.436.187-.35 1.558-.253c.317-.05.49-.466.3-.727l-.92-1.28.116-.38 1.477-.552c.3-.113.388-.553.153-.772l-1.156-1.078.038-.392 1.345-.832c.272-.168.273-.618 0-.787z" fill="rgba(250,250,250,0.5)"/></svg>
        </div>
        <div class="stack-label">Backend</div>
        <div class="stack-name">Rust</div>
        <div class="stack-desc">Daemon + Hub, zero-copy I/O</div>
      </div>
      <div class="stack-item">
        <div class="stack-logo">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 64 64"><path d="M63.93 17.608a17.91 17.91 0 0 0-.405-3.78c-.5-2.553-1.828-4.893-3.8-6.7a12.05 12.05 0 0 0-3.447-2.258c-1.243-.6-2.57-1-3.94-1.22-1.354-.25-2.85-.25-4.203-.368h-33.45a24.7 24.7 0 0 0-3.113.251c-1.027.114-2.033.36-3 .736l-.95.368a17.47 17.47 0 0 0-2.585 1.589c-.264.25-.545.368-.81.602a10.91 10.91 0 0 0-2.48 3.044C1.09 11.02.63 12.258.405 13.544A35.75 35.75 0 0 0 0 17.307V46.46a17.91 17.91 0 0 0 .405 3.78c.5 2.553 1.828 4.893 3.8 6.7a12.06 12.06 0 0 0 3.394 2.191c1.243.6 2.57 1 3.94 1.22 1.354.25 2.85.25 4.203.368h32.466a24.49 24.49 0 0 0 4.203-.368c1.344-.22 2.648-.627 3.87-1.204a15.54 15.54 0 0 0 3.517-2.191 10.9 10.9 0 0 0 2.445-3.044c.67-1.138 1.128-2.377 1.354-3.663a35.75 35.75 0 0 0 .405-3.78v-28.85z" fill="rgba(250,250,250,0.15)"/><path d="M42.737 47.713c-5.698 2.96-13.525 3.26-21.386.234C15.218 45.6 9.967 41.557 6.28 36.34c1.72 1.22 3.592 2.232 5.575 3.01c8.125 3.345 16.268 3.194 21.984 0c-7.545-5.46-14.34-11.798-20.225-18.866a21.17 21.17 0 0 1-2.708-3.345c6.18 4.937 12.754 9.41 19.663 13.38c-5.032-4.852-9.66-10.07-13.84-15.605C23.7 21.277 31.363 26.917 39.59 31.74l.88.468a15.18 15.18 0 0 0 .616-1.673c1.9-6.222-.264-13.296-5.012-19.15c10.992 5.97 17.5 17.193 14.79 26.593c0 .25-.14.502-.23.753l.088.1c5.434 6.105 3.94 12.56 3.254 11.34c-2.972-5.1-8.477-3.53-11.238-2.46z" fill="rgba(250,250,250,0.5)"/></svg>
        </div>
        <div class="stack-label">iOS</div>
        <div class="stack-name">Swift</div>
        <div class="stack-desc">SwiftUI, SwiftTerm, TCA</div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="how" id="how">
    <h2 class="section-title reveal">Three steps.<br><em>Two</em> minutes.</h2>
    <div class="steps">
      <div class="step reveal">
        <div class="step-number">1</div>
        <h3>Install</h3>
        <p>One command. Works on any Mac.</p>
        <code>curl -fsSL https://fil.sh/install.sh | sh</code>
      </div>
      <div class="step reveal">
        <div class="step-number">2</div>
        <h3>Authenticate</h3>
        <p>Sign in with GitHub. Browser opens, done.</p>
        <code>fil setup</code>
      </div>
      <div class="step reveal">
        <div class="step-number">3</div>
        <h3>Connect</h3>
        <p>Open the app on your iPhone. Sessions are there.</p>
        <code>fil</code>
      </div>
    </div>
  </section>

  <!-- Self-host -->
  <section class="selfhost reveal">
    <h2>Own your data.</h2>
    <p>Run the Fil hub on your own server.</p>
    <code>docker run -d -p 3100:3100 -p 16433:16433/udp fil/hub</code>
  </section>

  <!-- Footer -->
  <footer>
    <div class="footer-inner">
      <a href="/" class="logo">fil<span>.sh</span></a>
      <div class="links">
        <a href="https://github.com/Remenby31/fil">GitHub</a>
        <a href="/privacy">Privacy</a>
        <a href="mailto:hello@fil.sh">Contact</a>
      </div>
      <div class="copy">© 2026 Fil. MIT License.</div>
    </div>
  </footer>

  <!-- Scroll reveal script -->
  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>
</body>
</html>

<style>
  :root {
    --void: #0A0A0F;
    --fil-green: #00D4AA;
    --surface: #12121A;
    --cloud: #FAFAFA;
    --depth: #0D1117;
    --fil-light: #55EFC4;
    --text-secondary: rgba(250,250,250,0.45);
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Inter', -apple-system, sans-serif;
    background: var(--void);
    color: var(--cloud);
    overflow-x: hidden;
  }

  /* Scroll reveal */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .delay-1 { transition-delay: 0.1s; }
  .delay-2 { transition-delay: 0.2s; }
  .delay-3 { transition-delay: 0.3s; }

  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; transition: none; }
  }

  /* Nav */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10,10,15,0.8);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo { font-size: 20px; font-weight: 300; color: var(--cloud); text-decoration: none; }
  .logo span { color: var(--fil-green); }
  .nav-links { display: flex; gap: 24px; align-items: center; }
  .nav-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    transition: color 0.2s;
    display: inline-flex;
    align-items: center;
  }
  .nav-link:hover { color: var(--cloud); }

  /* Hero */
  .hero {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
    padding: 80px 24px 60px;
  }
  .hero-badge {
    display: inline-block;
    font-size: 12px;
    font-weight: 500;
    color: var(--fil-green);
    background: rgba(0,212,170,0.08);
    border: 1px solid rgba(0,212,170,0.15);
    padding: 6px 16px;
    border-radius: 100px;
    margin-bottom: 28px;
    letter-spacing: 0.3px;
  }
